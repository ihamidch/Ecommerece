PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ecommerce
JWT_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret

# Primary frontend URL allowed by CORS
CLIENT_URL=

# Optional additional frontend URLs (comma-separated)
# CLIENT_URLS=https://preview-1.vercel.app,https://preview-2.vercel.app

# Allow all *.vercel.app and *.onrender.com origins in production
# Default behavior in app is true unless explicitly set to false.
ALLOW_PREVIEW_ORIGINS=true

# Auth endpoint rate limit configuration (optional)
# AUTH_RATE_LIMIT_WINDOW_MS=600000
# AUTH_RATE_LIMIT_MAX=25

# Request logging toggle (enabled by default in development)
# LOG_REQUESTS=true

# Comma-separated emails that get admin role on signup
ADMIN_EMAILS=admin@example.com

# Cloudinary (optional but recommended for product image hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe (optional; app uses mock payment when not set)
STRIPE_SECRET_KEY=

# Set to true to skip auto-inserting demo products when catalog is empty
# SKIP_AUTO_DEMO_SEED=true
